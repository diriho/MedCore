{
   "name": "@builder106/medcore",
   "private": true,
   "version": "0.0.1",
   "type": "module",
   "scripts": {
      "dev": "concurrently -n web,api,tunnel -c cyan,magenta,green \"npm:dev:web\" \"npm:dev:api\" \"npm:tunnel\"",
      "dev:web": "vite",
      "dev:api": "npm --prefix server run dev",
      "tunnel": "bash scripts/tunnel.sh",
      "build": "vite build",
      "test": "vitest run",
      "test:all": "npm test && npm --prefix server test",
      "e2e": "bddgen test --config e2e/playwright.config.ts && playwright test --config=e2e/playwright.config.ts",
      "e2e:demo": "DEMO=1 bddgen test --config e2e/playwright.demo.config.ts && DEMO=1 playwright test --config=e2e/playwright.demo.config.ts",
      "e2e:demo:gif": "node scripts/mp4-to-gif.mjs"
   },
