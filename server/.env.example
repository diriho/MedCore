# ── Core server ──────────────────────────────────────────────────────────────
PORT=3001
SESSION_SECRET=replace-with-32-plus-random-chars-in-production
SESSION_MAX_AGE_DAYS=7
DATABASE_URL=./data/medcore.db

# ── PII encryption ────────────────────────────────────────────────────────────
# AES-256-GCM key — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank in dev. Set before any real patient data touches the database.
DATABASE_ENCRYPTION_KEY=

# ── AI assistant ──────────────────────────────────────────────────────────────
# Free tier at openrouter.ai — recommended for AI summaries and chat
OPENROUTER_API_KEY=
# Free Whisper via Groq (preferred) — console.groq.com
GROQ_API_KEY=
# OpenAI fallback for Whisper — only needed if not using Groq
OPENAI_API_KEY=

# ── Web Push (medication reminders) ──────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_CONTACT=mailto:demo@medcore.local

# ── Video consulting (Daily.co) ───────────────────────────────────────────────
DAILY_API_KEY=
DAILY_DOMAIN=

# ── SMS / Africa's Talking ────────────────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=MEDCORE
SMS_RESPONSE_TTL_MS=120000

# ── Voice recordings ──────────────────────────────────────────────────────────
AUDIO_RETENTION_DAYS=30

# ── Demo / seeded users ───────────────────────────────────────────────────────
DEMO_DOCTOR_PIN=4242
DEMO_PATIENT_PIN=1212
DEMO_ADMIN_PIN=3434
DEMO_DOCTOR_PHONE=
DEMO_PATIENT_PHONE=
DEMO_ADMIN_PHONE=
# Set to 1 in production so PIN changes above sync without wiping the DB
# MEDCORE_SYNC_DEMO_USERS=1
